# Token HuggingFace (gratuit) pour la reconnaissance d'assiette.
# Cree-le sur https://huggingface.co/settings/tokens (role: read), puis copie
# ce fichier en .env et renseigne la valeur.
EXPO_PUBLIC_HF_TOKEN=

# Optionnel : modele de classification d'image (defaut nateraw/food).
# EXPO_PUBLIC_HF_MODEL=nateraw/food
